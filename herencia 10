class Pago:
    def __init__(self, monto, fecha):
        self.monto = monto
        self.fecha = fecha

    def mostrar_detalles_pago(self):
        print(f"Fecha del Pago: {self.fecha} | Monto Registrado: ${self.monto}")

class PagoTarjeta(Pago):
    def __init__(self, monto, fecha, numero_tarjeta):
        super().__init__(monto, fecha)
        self.numero_tarjeta = numero_tarjeta

    def procesar_pago(self):
        print(f"Conectando con el banco... Cobrando ${self.monto} a la tarjeta {self.numero_tarjeta}.")

    def generar_recibo(self):
        print("=== RECIBO DE PAGO ===")
        self.mostrar_detalles_pago()
        print(f"Método: Tarjeta de Crédito/Débito ({self.numero_tarjeta})")
        print("======================")

class PagoPayPal(Pago):
    def __init__(self, monto, fecha, correo_usuario):
        super().__init__(monto, fecha)
        self.correo_usuario = correo_usuario

    def procesar_pago(self):
        print(f"Abriendo API de PayPal... Procesando cobro de ${self.monto} al usuario {self.correo_usuario}.")

    def generar_recibo(self):
        print("=== RECIBO DE PAGO ===")
        self.mostrar_detalles_pago()
        print(f"Método de Pago: Cuenta PayPal ({self.correo_usuario})")
        print("======================")
