ass Figura:
    def __init__(self, nombre, color):
        self.nombre = nombre
        self.color = color

class Circulo(Figura):
    def __init__(self, nombre, color, radio):
        super().__init__(nombre, color)
        self.radio = radio

    def calcular_area(self):
        return 3.1416 * self.radio * self.radio

    def calcular_perimetro(self):
        return 2 * 3.1416 * self.radio

    def imprimir_detalles(self):
        print(f"Figura: {self.nombre} | Color: {self.color} | Radio: {self.radio}")
        print(f"Área: {self.calcular_area()} | Perímetro: {self.calcular_perimetro()}")

class Rectangulo(Figura):
    def __init__(self, nombre, color, base, altura):
        super().__init__(nombre, color)
        self.base = base
        self.altura = altura

    def calcular_area(self):
        return self.base * self.altura

    def calcular_perimetro(self):
        return 2 * (self.base + self.altura)

    def imprimir_detalles(self):
        print(f"Figura: {self.nombre} | Color: {self.color} | Base: {self.base} | Altura: {self.altura}")
        print(f"Área: {self.calcular_area()} | Perímetro: {self.calcular_perimetro()}")
